{
  "name": "rescript-signals-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rescript -w & vite",
    "build": "npm run res:build && npm run build:client && npm run build:server && npm run build:prerender",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/EntryServer.res.mjs --outDir build/server",
    "build:prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "res:build": "rescript",
    "res:watch": "rescript -w",
    "res:clean": "rescript clean"
  },
  "dependencies": {
    "@rescript/core": "^1.6.1",
    "basefn": "^1.9.1",
    "rescript-signals": "^1.3.3",
    "xote": "^4.16.1"
  },
  "devDependencies": {
    "rescript": "^12.0.0",
    "vite": "^7.1.12"
  }
}
